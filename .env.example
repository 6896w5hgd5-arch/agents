# Plantilla de Variables de Entorno (NO colocar llaves reales en este archivo)
# Copiar este archivo como '.env' en tu entorno local y configurar tus valores reales.

# Google Antigravity / Gemini API Key
GEMINI_API_KEY=tu_api_key_aqui

# OpenAI API Key (si aplica)
OPENAI_API_KEY=tu_api_key_aqui

# Entorno de trabajo
ENVIRONMENT=development
LOG_LEVEL=info
